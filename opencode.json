{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "sqlite": {
      "type": "local",
      "command": [
        "sh",
        "-c",
        "uvx mcp-sqlite $(find . -maxdepth 3 -name '*.db' -o -name '*.sqlite' | head -1)"
      ],
      "enabled": false
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": false
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": false
    },
    "fetch": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-fetch"
      ],
      "enabled": true
    }
  },
  "agent": {
    "coder": {
      "description": "General purpose coding agent",
      "mode": "subagent",
      "prompt": "You are an expert software engineer. Write clean, idiomatic code with proper error handling. Prefer simple solutions over clever ones. Always consider edge cases."
    },
    "reviewer": {
      "description": "Code review and quality analysis",
      "mode": "subagent",
      "prompt": "You are a senior code reviewer. Focus on correctness, security, performance, and maintainability. Be direct and specific in your feedback."
    },
    "architect": {
      "description": "System design and architecture decisions",
      "mode": "subagent",
      "prompt": "You are a software architect. Help design systems that are scalable, maintainable, and pragmatic. Always weigh tradeoffs explicitly before recommending an approach."
    }
  }
}
